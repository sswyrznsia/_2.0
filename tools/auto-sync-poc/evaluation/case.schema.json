{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Automatic sync evaluation case",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "audioPath", "plainLyrics", "originalSyncedLyrics", "keywordHotwords"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "audioPath": { "type": "string", "minLength": 1 },
    "plainLyrics": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "originalSyncedLyrics": { "type": "string", "minLength": 1 },
    "keywordHotwords": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "groundTruthPath": { "type": "string", "minLength": 1 },
    "groundTruthAnchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["lineIndex", "audioTimeMs"],
        "properties": {
          "lineIndex": { "type": "integer", "minimum": 0 },
          "audioTimeMs": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "errorAnnotations": {
      "type": "array",
      "items": { "$ref": "ground-truth.schema.json#/$defs/errorAnnotation" }
    }
  },
  "oneOf": [
    { "required": ["groundTruthPath"] },
    { "required": ["groundTruthAnchors"] }
  ]
}
