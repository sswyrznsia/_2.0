{
  "manifest_version": 3,
  "name": "Pulse Shelf YouTube Extension Test",
  "version": "1.0.0",
  "description": "Verifies Electron unpacked-extension loading in the YouTube view.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*", "https://music.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://music.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
